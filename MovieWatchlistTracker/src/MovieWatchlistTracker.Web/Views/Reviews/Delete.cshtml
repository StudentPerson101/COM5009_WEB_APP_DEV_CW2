@model ReviewEditViewModel

@{
    ViewData["Title"] = "Delete Review";
}

<section class="content-section">
    <h1>Delete Review</h1>
    <p class="lead">Delete your review for this movie?</p>
    <blockquote class="border-start border-3 ps-3 text-muted">@Model.Text</blockquote>
    <form asp-action="Delete" method="post">
        <input asp-for="Id" type="hidden" name="id" />
        <input asp-for="MovieId" type="hidden" name="movieId" />
        <button type="submit" class="btn btn-danger" data-confirm="Delete this review?">Delete Review</button>
        <a class="btn btn-outline-secondary" asp-controller="Movies" asp-action="Details" asp-route-id="@Model.MovieId">Cancel</a>
    </form>
</section>
