@model HistoryViewModel

@{
    ViewData["Title"] = "Watched History";
}

<section class="browse-header" aria-labelledby="history-title">
    <div>
        <p class="eyebrow">Watched movies</p>
        <h1 id="history-title">Watched / History</h1>
    </div>
    <div class="browse-summary" aria-label="Watched movie count">
        <strong>@Model.Items.Count</strong>
        <span>watched</span>
    </div>
</section>

<form class="filter-bar filter-bar--compact" asp-controller="History" asp-action="Index" method="get" aria-label="History filters">
    <div class="filter-field">
        <label class="form-label" for="genreId">Genre</label>
        <select id="genreId" class="form-select" name="genreId">
            <option value="">All genres</option>
            @foreach (var genre in Model.Genres)
            {
                <option value="@genre.Id" selected="@(Model.SelectedGenreId == genre.Id)">@genre.Name</option>
            }
        </select>
    </div>
    <div class="filter-field">
        <label class="form-label" for="sortBy">Sort</label>
        <select id="sortBy" class="form-select" name="sortBy">
            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SortBy))">Recently watched</option>
            <option value="title" selected="@(Model.SortBy == "title")">Title</option>
            <option value="year" selected="@(Model.SortBy == "year")">Release year</option>
            <option value="rating" selected="@(Model.SortBy == "rating")">Rating</option>
        </select>
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary" type="submit">Apply</button>
        <a class="btn btn-outline-secondary" asp-controller="History" asp-action="Index">Reset</a>
    </div>
</form>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success mt-3" role="status">@statusMessage</div>
}

<section class="content-section" aria-label="Watched movie list">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h2>No watched movies</h2>
            <a class="btn btn-primary" asp-controller="Movies" asp-action="Index">Browse Movies</a>
        </div>
    }
    else
    {
        <div class="media-list">
            @foreach (var item in Model.Items)
            {
                <article class="media-row">
                    <a class="poster-frame poster-frame--small" asp-controller="Movies" asp-action="Details" asp-route-id="@item.MovieId" aria-label="Open @item.Title details">
                        @if (!string.IsNullOrWhiteSpace(item.PosterUrl))
                        {
                            <img src="@item.PosterUrl" alt="@item.Title cover" loading="lazy" onerror="this.remove();" />
                        }
                        <span class="poster-fallback" aria-hidden="true">@item.Title.Substring(0, 1)</span>
                    </a>
                    <div class="media-row-body">
                        <div>
                            <h2><a asp-controller="Movies" asp-action="Details" asp-route-id="@item.MovieId">@item.Title</a></h2>
                            <p class="muted">
                                @(item.ReleaseYear?.ToString() ?? "Year TBA")
                                <span aria-hidden="true"> | </span>
                                @(item.Genres.Count == 0 ? "Uncategorized" : string.Join(", ", item.Genres))
                            </p>
                            <p class="muted">Watched @(item.WatchedAt?.ToString("MMM d, yyyy") ?? item.AddedAt.ToString("MMM d, yyyy"))</p>
                        </div>
                        <div class="media-row-meta">
                            <span class="status-pill">watched</span>
                            <span>@(item.AverageRating.HasValue ? $"{RatingDisplayFormatter.Format(item.AverageRating)}/10" : "No ratings")</span>
                        </div>
                        <div class="row-actions">
                            <a class="btn btn-outline-secondary btn-sm" asp-controller="Movies" asp-action="Details" asp-route-id="@item.MovieId">Review</a>
                            <form asp-controller="History" asp-action="Remove" method="post">
                                <input type="hidden" name="movieId" value="@item.MovieId" />
                                <button class="btn btn-outline-danger btn-sm" type="submit" data-confirm="Remove @item.Title from watched history and mark it unwatched?" aria-label="Remove @item.Title from watched history">Remove from History</button>
                            </form>
                            <form asp-controller="History" asp-action="MarkWatched" method="post">
                                <input type="hidden" name="movieId" value="@item.MovieId" />
                                <button class="btn btn-outline-primary btn-sm" type="submit" aria-label="Record @item.Title as watched again">Watch Again</button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
