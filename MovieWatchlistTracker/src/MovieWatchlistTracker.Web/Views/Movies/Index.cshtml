@model MovieSearchViewModel
@using MovieWatchlistTracker.Web.Services.Interfaces
@inject IAppearanceSettingsService AppearanceSettings
@inject IBrowsePageContentService BrowsePageContent

@{
    ViewData["Title"] = "Browse Movies";
    var appearanceSettings = await AppearanceSettings.GetSettingsAsync();
    var browsePageContent = await BrowsePageContent.GetSettingsAsync();
    var returnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
}

@if (!string.IsNullOrWhiteSpace(appearanceSettings.BannerPath))
{
    <section class="home-banner" aria-label="Movie Watchlist Tracker banner">
        <img src="@appearanceSettings.BannerPath" alt="Movie Watchlist Tracker" />
    </section>
}

<section class="browse-header" aria-labelledby="browse-title">
    <div>
        <p class="eyebrow browse-page-eyebrow">@browsePageContent.EyebrowText</p>
        <h1 id="browse-title" class="browse-page-heading">@browsePageContent.HeadingText</h1>
    </div>
    <div class="browse-summary" aria-label="Browse result count">
        <strong>@Model.Movies.Count</strong>
        <span>movies</span>
    </div>
</section>

@if (User.IsInRole("Admin"))
{
    <details class="admin-form browse-heading-editor">
        <summary>Edit Browse Page Headings</summary>
        <form asp-controller="AdminBrowsePageContent" asp-action="Update" method="post">
            <input type="hidden" name="ReturnUrl" value="@returnUrl" />
            <div class="browse-heading-editor-grid">
                <div>
                    <label class="form-label" for="browse-heading-eyebrow">Edit Browse Eyebrow Text</label>
                    <input id="browse-heading-eyebrow" class="form-control" name="EyebrowText" value="@browsePageContent.EyebrowText" maxlength="80" required />
                </div>
                <div>
                    <label class="form-label" for="browse-heading-title">Edit Browse Heading Text</label>
                    <input id="browse-heading-title" class="form-control" name="HeadingText" value="@browsePageContent.HeadingText" maxlength="140" required />
                </div>
            </div>
            <div class="admin-form-actions">
                <button class="btn btn-primary" type="submit">Save Headings</button>
            </div>
        </form>
    </details>
}

<form class="filter-bar" asp-controller="Movies" asp-action="Index" method="get" aria-label="Movie search and filters">
    <div class="filter-field filter-field--wide">
        <label class="form-label" for="query">Search</label>
        <div class="autocomplete-field" data-movie-autocomplete>
            <input id="query"
                   class="form-control"
                   type="search"
                   name="query"
                   value="@Model.Query"
                   placeholder="Movie title"
                   autocomplete="off"
                   aria-autocomplete="list"
                   aria-expanded="false"
                   aria-controls="movie-title-suggestions"
                   data-movie-autocomplete-input
                   data-suggestions-url="@Url.Action("Suggestions", "Movies")" />
            <div id="movie-title-suggestions"
                 class="autocomplete-menu"
                 role="listbox"
                 aria-label="Movie title suggestions"
                 hidden
                 data-movie-autocomplete-menu></div>
        </div>
    </div>
    <div class="filter-field">
        <label class="form-label" for="genreId">Genre</label>
        <select id="genreId" class="form-select" name="genreId">
            <option value="">All genres</option>
            @foreach (var genre in Model.Genres)
            {
                <option value="@genre.Id" selected="@(Model.SelectedGenreId == genre.Id)">@genre.Name</option>
            }
        </select>
    </div>
    <div class="filter-field">
        <label class="form-label" for="year">Year</label>
        <input id="year" class="form-control" type="number" name="year" value="@Model.SelectedYear" min="1888" max="2100" placeholder="Any" />
    </div>
    <div class="filter-field">
        <label class="form-label" for="minimumRating">Rating</label>
        <select id="minimumRating" class="form-select" name="minimumRating">
            <option value="">Any rating</option>
            @for (var rating = 10; rating >= 1; rating--)
            {
                <option value="@rating" selected="@(Model.SelectedRating == rating)">@($"{rating}+ / 10")</option>
            }
        </select>
    </div>
    <div class="filter-field">
        <label class="form-label" for="watchedStatus">Watched</label>
        <select id="watchedStatus" class="form-select" name="watchedStatus">
            <option value="">Any status</option>
            <option value="watched" selected="@(Model.SelectedWatchedStatus == "watched")">Watched</option>
            <option value="unwatched" selected="@(Model.SelectedWatchedStatus == "unwatched")">Unwatched</option>
        </select>
    </div>
    <div class="filter-field">
        <label class="form-label" for="sortBy">Sort</label>
        <select id="sortBy" class="form-select" name="sortBy">
            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SortBy))">Title</option>
            <option value="year" selected="@(Model.SortBy == "year")">Newest</option>
            <option value="rating" selected="@(Model.SortBy == "rating")">Top rated</option>
        </select>
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary" type="submit">Apply</button>
        <a class="btn btn-outline-secondary" asp-controller="Movies" asp-action="Index">Reset</a>
    </div>
</form>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success mt-3" role="status">@statusMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger mt-3" role="alert">@errorMessage</div>
}

<section class="content-section" aria-labelledby="popular-heading">
    <div class="section-heading">
        <h2 id="popular-heading">Popular Movies</h2>
    </div>

    @if (Model.Movies.Count == 0)
    {
        <div class="empty-state">
            <h2>No movies found</h2>
            <p>Try a different title, genre, year, or rating.</p>
        </div>
    }
    else
    {
        <div class="movie-grid">
            @foreach (var movie in Model.Movies)
            {
                <partial name="_MovieCard" model="movie" />
            }
        </div>
    }
</section>
