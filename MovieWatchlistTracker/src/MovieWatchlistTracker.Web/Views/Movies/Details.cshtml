@model MovieDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="status">@statusMessage</div>
}

<section class="details-layout" aria-labelledby="movie-title">
    <div class="details-poster poster-frame poster-frame--large">
        @if (!string.IsNullOrWhiteSpace(Model.PosterUrl))
        {
            <img src="@Model.PosterUrl" alt="@Model.Title poster" loading="lazy" onerror="this.remove();" />
        }
        <span class="poster-fallback" aria-hidden="true">@Model.Title.Substring(0, 1)</span>
    </div>

    <div class="details-main">
        <p class="eyebrow">Movie Details</p>
        <h1 id="movie-title">@Model.Title</h1>
        <p class="movie-facts">
            @(Model.ReleaseYear?.ToString() ?? "Year TBA")
            <span aria-hidden="true"> | </span>
            @(Model.Genres.Count == 0 ? "Uncategorized" : string.Join(", ", Model.Genres))
            <span aria-hidden="true"> | </span>
            Duration @Model.DisplayDuration
        </p>
        <p class="details-description">@(Model.Description ?? "No description is available yet.")</p>
        <div class="meta-row meta-row--inline">
            <span>@(Model.AverageRating.HasValue ? $"{Model.AverageRating}/5 average" : "No ratings yet")</span>
            <span>@(Model.IsWatched ? "Watched" : "Not watched")</span>
            <span>@(Model.IsInWatchlist ? "Saved" : "Not saved")</span>
        </div>

        <div class="action-row" aria-label="Movie actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (!Model.IsInWatchlist)
                {
                    <form asp-controller="Watchlists" asp-action="AddMovie" method="post">
                        <input type="hidden" name="movieId" value="@Model.MovieId" />
                        <button class="btn btn-primary" type="submit" aria-label="Add @Model.Title to watchlist">Add to Watchlist</button>
                    </form>
                }
                else
                {
                    <form asp-controller="Watchlists" asp-action="RemoveMovie" method="post">
                        <input type="hidden" name="movieId" value="@Model.MovieId" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Movies", new { id = Model.MovieId })" />
                        <button class="btn btn-outline-danger" type="submit" data-confirm="Remove @Model.Title from your watchlist?" aria-label="Remove @Model.Title from your watchlist">Remove from Watchlist</button>
                    </form>
                }
                @if (Model.IsWatched)
                {
                    <form asp-controller="History" asp-action="Remove" method="post">
                        <input type="hidden" name="movieId" value="@Model.MovieId" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Movies", new { id = Model.MovieId })" />
                        <button class="btn btn-outline-secondary" type="submit" data-confirm="Remove @Model.Title from your watched history and mark it unwatched?" aria-label="Remove @Model.Title from watched history">Remove from History</button>
                    </form>
                }
                else
                {
                    <form asp-controller="History" asp-action="MarkWatched" method="post">
                        <input type="hidden" name="movieId" value="@Model.MovieId" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Movies", new { id = Model.MovieId })" />
                        <button class="btn btn-outline-secondary" type="submit" aria-label="Mark @Model.Title as watched">Mark Watched</button>
                    </form>
                }
            }
            else
            {
                <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Log in to Track</a>
            }
        </div>
    </div>
</section>

<section class="review-layout" aria-label="Ratings and reviews">
    <div class="review-panel">
        <div class="section-heading">
            <h2>Your Rating</h2>
            @if (Model.CurrentUserRating.HasValue)
            {
                <span class="status-pill">@Model.CurrentUserRating/5</span>
            }
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Ratings" asp-action="CreateOrUpdate" method="post" class="rating-form">
                <input type="hidden" name="MovieId" value="@Model.MovieId" />
                <span class="visually-hidden" id="rating-help">Choose a rating from 1 to 5.</span>
                <div class="rating-options" role="radiogroup" aria-label="Choose rating">
                    @for (var score = 1; score <= 5; score++)
                    {
                        <input class="btn-check" type="radio" name="Score" id="rating-@score" value="@score" checked="@(Model.CurrentUserRating == score)" required aria-describedby="rating-help" />
                        <label class="btn btn-outline-primary" for="rating-@score" aria-label="@score out of 5">@score</label>
                    }
                </div>
                <button class="btn btn-primary" type="submit">Save Rating</button>
            </form>
            @if (Model.CurrentUserRatingId.HasValue)
            {
                <form asp-controller="Ratings" asp-action="Delete" asp-route-id="@Model.CurrentUserRatingId" asp-route-movieId="@Model.MovieId" method="post">
                    <button class="btn btn-link danger-link inline-delete-button" type="submit" data-confirm="Delete your rating for @Model.Title?" aria-label="Delete your rating for @Model.Title">Delete Rating</button>
                </form>
            }
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">Log in to rate this movie</a>
        }
    </div>

    <div class="review-panel">
        <div class="section-heading">
            <h2>Your Review</h2>
            @if (Model.CurrentUserReviewId.HasValue)
            {
                <a asp-controller="Reviews" asp-action="Edit" asp-route-id="@Model.CurrentUserReviewId">Edit</a>
            }
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Reviews" asp-action="Create" method="post" class="review-form">
                <input type="hidden" name="MovieId" value="@Model.MovieId" />
                <label class="form-label" for="review-text">Review</label>
                <textarea id="review-text" class="form-control" name="Text" rows="6" maxlength="4000" required aria-describedby="review-help">@Model.CurrentUserReview</textarea>
                <div class="field-help" id="review-help">
                    <span>Reviews are shown on the movie details page.</span>
                    <span data-character-count-for="review-text">0 / 4000</span>
                </div>
                <button class="btn btn-primary" type="submit">Save Review</button>
            </form>
            @if (Model.CurrentUserReviewId.HasValue)
            {
                <form asp-controller="Reviews" asp-action="Delete" asp-route-id="@Model.CurrentUserReviewId" method="post">
                    <input type="hidden" name="movieId" value="@Model.MovieId" />
                    <button class="btn btn-link danger-link inline-delete-button" type="submit" data-confirm="Delete your review for @Model.Title?" aria-label="Delete your review for @Model.Title">Delete Review</button>
                </form>
            }
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">Log in to write a review</a>
        }
    </div>
</section>

<section class="content-section" aria-labelledby="reviews-heading">
    <div class="section-heading">
        <h2 id="reviews-heading">Other Reviews</h2>
    </div>

    @if (Model.OtherReviews.Count == 0)
    {
        <div class="empty-state">
            <h2>No reviews yet</h2>
            <p>This movie has not been reviewed.</p>
        </div>
    }
    else
    {
        <div class="review-list">
            @foreach (var review in Model.OtherReviews)
            {
                <article class="review-item">
                    <div>
                        <h3>
                            @review.ReviewerName
                            @if (review.IsCurrentUserReview)
                            {
                                <span class="status-pill">You</span>
                            }
                        </h3>
                        <p class="muted">
                            @(review.Rating.HasValue ? $"{review.Rating}/5" : "No rating")
                            <span aria-hidden="true"> | </span>
                            Updated @review.UpdatedAt.ToString("MMM d, yyyy")
                        </p>
                    </div>
                    <p>@review.Text</p>
                </article>
            }
        </div>
    }
</section>
