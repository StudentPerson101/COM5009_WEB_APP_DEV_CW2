@model AdminMovieDetailsViewModel

@{
    ViewData["Title"] = "Delete Movie";
}

<section class="browse-header" aria-labelledby="delete-movie-title">
    <div>
        <p class="eyebrow">Admin</p>
        <h1 id="delete-movie-title">Delete @Model.Title</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Back</a>
</section>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<section class="content-section">
    <p>Deleting a movie removes it from the catalog. This action is blocked while user data references the movie.</p>

    <div class="alert @(Model.HasUserData ? "alert-warning" : "alert-danger")" role="alert">
        <strong>Related data:</strong>
        @Model.WatchlistItemCount watchlist items,
        @Model.ViewingHistoryCount viewing-history records,
        @Model.RatingCount ratings,
        @Model.ReviewCount reviews.
    </div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button class="btn btn-danger" type="submit" disabled="@Model.HasUserData">Delete Movie</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
    </form>
</section>
