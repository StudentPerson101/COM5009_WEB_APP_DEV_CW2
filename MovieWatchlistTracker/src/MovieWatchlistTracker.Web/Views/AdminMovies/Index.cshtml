@model AdminMovieIndexViewModel

@{
    ViewData["Title"] = "Admin Movies";
}

<section class="browse-header" aria-labelledby="admin-movies-title">
    <div>
        <p class="eyebrow">Admin</p>
        <h1 id="admin-movies-title">Movie Catalog</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Movie</a>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="status">@statusMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<form class="filter-bar" asp-action="Index" method="get" aria-label="Admin movie catalog filters">
    <div class="filter-field filter-field--wide">
        <label class="form-label" for="query">Search</label>
        <div class="autocomplete-field" data-movie-autocomplete>
            <input id="query"
                   class="form-control"
                   type="search"
                   name="query"
                   value="@Model.Query"
                   placeholder="Movie title"
                   autocomplete="off"
                   aria-autocomplete="list"
                   aria-expanded="false"
                   aria-controls="admin-movie-title-suggestions"
                   data-movie-autocomplete-input
                   data-suggestions-url="@Url.Action("Suggestions", "Movies")" />
            <div id="admin-movie-title-suggestions"
                 class="autocomplete-menu"
                 role="listbox"
                 aria-label="Admin movie title suggestions"
                 hidden
                 data-movie-autocomplete-menu></div>
        </div>
    </div>
    <div class="filter-field">
        <label class="form-label" for="genreId">Genre</label>
        <select id="genreId" class="form-select" name="genreId">
            <option value="">All genres</option>
            @foreach (var genre in Model.Genres)
            {
                <option value="@genre.Id" selected="@(Model.SelectedGenreId == genre.Id)">@genre.Name</option>
            }
        </select>
    </div>
    <div class="filter-field">
        <label class="form-label" for="sortBy">Sort</label>
        <select id="sortBy" class="form-select" name="sortBy">
            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SortBy))">Title</option>
            <option value="year" selected="@(Model.SortBy == "year")">Newest</option>
            <option value="runtime" selected="@(Model.SortBy == "runtime")">Duration</option>
        </select>
    </div>
    <div class="filter-actions">
        <button class="btn btn-primary" type="submit">Apply</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
    </div>
</form>

<section class="content-section" aria-labelledby="movie-table-heading">
    <div class="section-heading">
        <h2 id="movie-table-heading">Stored Movies</h2>
        <div class="action-row">
            <a asp-controller="AdminGenres" asp-action="Index">Manage genres</a>
            <a asp-controller="AdminMaintenance" asp-action="Index">Cover maintenance</a>
        </div>
    </div>

    @if (Model.Movies.Count == 0)
    {
        <div class="empty-state">
            <h2>No movies found</h2>
            <p>Create a movie or change the filters.</p>
        </div>
    }
    else
    {
        <div class="table-responsive admin-table-wrap">
            <table class="table align-middle admin-table">
                <thead>
                    <tr>
                        <th scope="col">Movie</th>
                        <th scope="col">Genres</th>
                        <th scope="col">Duration</th>
                        <th scope="col">Related data</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movie in Model.Movies)
                    {
                        <tr>
                            <td>
                                <strong>@movie.Title</strong>
                                <span class="text-muted d-block">@(movie.ReleaseYear?.ToString() ?? "Year unknown")</span>
                                @if (!string.IsNullOrWhiteSpace(movie.ExternalApiId))
                                {
                                    <span class="text-muted d-block">External ID: @movie.ExternalApiId</span>
                                }
                            </td>
                            <td>@(movie.Genres.Count == 0 ? "None" : string.Join(", ", movie.Genres))</td>
                            <td>@movie.DisplayDuration</td>
                            <td>
                                <span class="admin-meta">@movie.WatchlistItemCount watchlist</span>
                                <span class="admin-meta">@movie.ViewingHistoryCount history</span>
                                <span class="admin-meta">@movie.RatingCount ratings</span>
                                <span class="admin-meta">@movie.ReviewCount reviews</span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Admin actions for @movie.Title">
                                    <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@movie.Id">Details</a>
                                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@movie.Id">Edit</a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@movie.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
