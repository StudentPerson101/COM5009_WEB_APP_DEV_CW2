@model ProfileViewModel

@{
    ViewData["Title"] = "Profile";
}

<section class="content-section">
    <h1>Profile</h1>
    <p class="lead">Your account is protected by ASP.NET Core Identity sessions and password hashing.</p>

    <dl class="row">
        <dt class="col-sm-3">Username</dt>
        <dd class="col-sm-9">@Model.UserName</dd>
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Member since</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</dd>
    </dl>

    <div class="row g-3">
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-2 p-3 h-100">
                <div class="text-muted small">Watchlists</div>
                <div class="fs-3 fw-semibold">@Model.WatchlistCount</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-2 p-3 h-100">
                <div class="text-muted small">Watched</div>
                <div class="fs-3 fw-semibold">@Model.WatchedCount</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-2 p-3 h-100">
                <div class="text-muted small">Ratings</div>
                <div class="fs-3 fw-semibold">@Model.RatingCount</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-2 p-3 h-100">
                <div class="text-muted small">Reviews</div>
                <div class="fs-3 fw-semibold">@Model.ReviewCount</div>
            </div>
        </div>
    </div>
</section>
