@model AdminGenreIndexViewModel

@{
    ViewData["Title"] = "Admin Genres";
}

<section class="browse-header" aria-labelledby="admin-genres-title">
    <div>
        <p class="eyebrow">Admin</p>
        <h1 id="admin-genres-title">Genres</h1>
    </div>
    <div class="btn-toolbar gap-2" role="toolbar" aria-label="Genre admin actions">
        <a class="btn btn-outline-secondary" asp-controller="AdminMovies" asp-action="Index">Movies</a>
        <a class="btn btn-primary" asp-action="Create">Add Genre</a>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="status">@statusMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<section class="content-section" aria-labelledby="genre-table-heading">
    <div class="section-heading">
        <h2 id="genre-table-heading">Stored Genres</h2>
    </div>

    @if (Model.Genres.Count == 0)
    {
        <div class="empty-state">
            <h2>No genres found</h2>
            <p>Create a genre before assigning genres to movies.</p>
        </div>
    }
    else
    {
        <div class="table-responsive admin-table-wrap">
            <table class="table align-middle admin-table">
                <thead>
                    <tr>
                        <th scope="col">Genre</th>
                        <th scope="col">Assigned movies</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var genre in Model.Genres)
                    {
                        <tr>
                            <td><strong>@genre.Name</strong></td>
                            <td>@genre.MovieCount</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Admin actions for @genre.Name">
                                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@genre.Id">Edit</a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@genre.Id">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
